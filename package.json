{
  "name": "tracklog-assist",
  "version": "0.1.42",
  "private": true,
  "description": "Truck operation log native app with offline support and day-based segment calculations.",
  "tracklogRelease": {
    "githubOwner": "Koutacode",
    "githubRepo": "tracklog-pwa",
    "apkAssetName": "tracklog-assist-debug.apk",
    "localApkPath": "output/tracklog-assist-debug.apk"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pwa": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:logic": "tsx src/app/authCallbackRouting.test.ts && tsx src/domain/regulationTimeline.test.ts && tsx src/domain/routePointTelemetry.test.ts && tsx src/domain/reportSyncConflict.test.ts && tsx src/app/nativeResidentLocationPolicy.test.ts && tsx src/services/driverProfileValidation.test.ts && node src/services/pushRegistration.test.mjs && node supabase/functions/tracklog-privileged/index.static.test.mjs && node --experimental-strip-types --test supabase/functions/tracklog-ic-resolver/resolver.test.mjs",
    "test:sync": "node scripts/test-tracklog-sync-v2.mjs",
    "check:csp": "node scripts/check-csp-endpoints.mjs",
    "cap:sync:android": "npx cap sync android",
    "normalize:android-assets": "powershell -ExecutionPolicy Bypass -File scripts/normalize-capacitor-assets.ps1",
    "deploy:pages": "wrangler pages deploy dist --project-name tracklog-assist",
    "release:prepare": "powershell -ExecutionPolicy Bypass -File skills/tracklog-release-notion/scripts/prepare-tracklog-release.ps1 -Build -SyncAndroid -AssembleDebug",
    "release:verify:apk": "powershell -ExecutionPolicy Bypass -File scripts/verify-latest-release-apk.ps1",
    "sync:notion:push": "node scripts/sync_notion_from_github.mjs",
    "sync:notion:pull": "node scripts/pull_notion_status_to_repo.mjs"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/android": "^8.0.2",
    "@capacitor/app": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/local-notifications": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@supabase/supabase-js": "^2.58.0",
    "dexie": "^4.2.1",
    "firebase": "^12.15.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.11.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "tsx": "4.23.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "wrangler": "^4.78.0"
  }
}
